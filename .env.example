# ==============================================================================
# Nutrico SaaS — Environment Variables
# File: .env.example
#
# Copy this file to .env and fill in all values before running docker compose.
# The .env file must NEVER be committed to version control.
# Production secrets should be injected via the host environment or a secrets
# manager (Docker Secrets, AWS SSM, etc.) — .env is for local dev only.
#
# Variable ownership:
#   [api]        — read by the Go API container
#   [worker]     — read by the Go Asynq worker container
#   [web]        — read at Next.js build time or runtime
#   [compose]    — used by docker compose itself (not passed to containers)
# ==============================================================================


# ------------------------------------------------------------------------------
# COMPOSE / INFRASTRUCTURE
# [compose] — used by docker compose and Traefik labels
# ------------------------------------------------------------------------------

# Public domain for the app. Traefik uses this for routing and TLS certs.
# Example: nutrico.com
APP_DOMAIN=localhost

# Timezone for the Traefik container.
TZ=UTC

# Email used by Let's Encrypt ACME registration (Traefik).
# Must be a valid inbox for expiry/security notices from Let's Encrypt.
ACME_EMAIL=admin@localhost

# PostgreSQL database name.
POSTGRES_DB=nutrico

# PostgreSQL container port used inside Docker network.
# Change this if you want PostgreSQL to listen on a non-default port.
POSTGRES_PORT=5432

# Optional host port mapping for local inspection when ports are enabled in compose.
POSTGRES_HOST_PORT=5432

# Host path used to persist PostgreSQL data on your PC disk.
# Use an absolute path on Windows (forward slashes recommended).
# Example: C:/docker-data/nutrico/postgres
POSTGRES_DATA_PATH=C:\dev\persistance\postgres

# PostgreSQL superuser username and password. Used only by the postgres container and the
# connection strings below. Never exposed outside the internal Docker network.
POSTGRES_SUPERUSER=postgres
POSTGRES_PASSWORD=admin

# Restricted runtime DB credentials used by api/worker (least privilege).
# Must match the role created in deploy/postgres/02-roles.sql.
POSTGRES_APP_DB_USER=nutrico_user
POSTGRES_APP_DB_PASSWORD=admin

# Redis authentication secrets.
# Both Redis instances require auth and the app connects via REDIS_*_URL.
REDIS_CACHE_PASSWORD=cache-dev-password
REDIS_QUEUE_PASSWORD=queue-dev-password

# pgAdmin default login credentials (dev only).
# Open pgAdmin at: http://localhost:5050
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change-me-pgadmin

# ------------------------------------------------------------------------------
# APP ENVIRONMENT
# [api] [worker] [web]
# ------------------------------------------------------------------------------

# Affects logging level and error verbosity.
# Values: development | staging | production
APP_ENV=development


# ------------------------------------------------------------------------------
# API — Go REST API
# [api]
# ------------------------------------------------------------------------------

# Full connection string for PostgreSQL.
# In docker compose this is assembled automatically from the variables above.
# Set explicitly only when connecting to an external database.
# DATABASE_URL=postgres://postgres:changeme@postgres:5432/nutrico?sslmode=disable

# Public base URL of the application. Used to construct magic link URLs,
# email verification links, and pre-signed download links.
# Must include scheme and no trailing slash.
# Example: https://nutrico.app
BASE_URL=http://localhost

# SMTP Gmail (2FA + App Password required)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@example.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=your-gmail-address@gmail.com

# HMAC-SHA256 signing secret for JWT access tokens.
# Generate with: openssl rand -hex 32
# Must be at least 32 random bytes. Never reuse across environments.
JWT_SECRET=replace-with-openssl-rand-hex-32

# Separate HMAC secret for refresh token signing.
# Must differ from JWT_SECRET.
# Generate with: openssl rand -hex 32
REFRESH_TOKEN_SECRET=replace-with-a-different-openssl-rand-hex-32

# bcrypt cost factor for password hashing.
# 12 is the production default. Use 4 in test environments for speed.
BCRYPT_COST=12

# Maximum size in MB for a single uploaded invoice XML file.
INVOICE_UPLOAD_MAX_MB=10

# Maximum number of invoice XML files per upload request.
INVOICE_UPLOAD_MAX_FILES=20

# Alpha factor for the Exponentially Weighted Moving Average used when
# updating ingredient unit costs from confirmed invoices.
# Range: 0.0–1.0. Higher = more weight on the latest invoice price.
# 0.3 is a sensible default (smooths spikes, tracks drift).
EWMA_ALPHA=0.3

# ------------------------------------------------------------------------------
# EMAIL (SMTP Gmail)
# [api]
# Gmail requires an App Password (2FA enabled on account).
# ------------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=Nutrico <your-gmail-address@gmail.com>


# ------------------------------------------------------------------------------
# WORKER — Go Asynq worker
# [worker]
# ------------------------------------------------------------------------------

# Number of concurrent Asynq worker goroutines.
# Increase for higher throughput if the host has available cores.
ASYNQ_CONCURRENCY=10

# Resend API key for transactional email.
# Get yours at: https://resend.com
RESEND_API_KEY=re_your_resend_api_key

# From address for all outbound emails.
EMAIL_FROM=noreply@nutrico.app


# ------------------------------------------------------------------------------
# REDIS
# [api] [worker]
# Both URLs are assembled by docker compose from the service names.
# Set explicitly only when connecting to external Redis instances.
# ------------------------------------------------------------------------------

# Volatile Redis — sessions and one-time tokens (magic link, email verify,
# password reset). No persistence. Users are logged out on restart.
# REDIS_CACHE_URL=redis://redis-cache:6379

# Durable Redis — Asynq task queue broker. AOF persistence, noeviction.
# REDIS_QUEUE_URL=redis://redis-queue:6379


# ------------------------------------------------------------------------------
# GOOGLE OAUTH
# [api]
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${BASE_URL}/api/auth/oauth/google/callback
# ------------------------------------------------------------------------------

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret


# ------------------------------------------------------------------------------
# STRIPE
# [api] [worker]
# ------------------------------------------------------------------------------

# Stripe secret key. Use sk_test_... for dev, sk_live_... for production.
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Stripe webhook endpoint signing secret.
# Create a webhook endpoint in the Stripe dashboard pointing to:
# ${BASE_URL}/api/billing/webhook
# Then copy the signing secret (whsec_...) here.
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret


# ------------------------------------------------------------------------------
# NEXT.JS FRONTEND
# [web]
# Variables prefixed with NEXT_PUBLIC_ are inlined at build time and exposed
# to the browser. Never put secrets here.
# ------------------------------------------------------------------------------

# The public-facing URL of the Go API, as seen from the browser.
# In production this is the same domain with /api prefix handled by Traefik.
# Example: https://nutrico.app
NEXT_PUBLIC_API_URL=http://localhost
